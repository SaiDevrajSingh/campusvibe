rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow read access to user profiles (more permissive for development)
      allow read: if isSignedIn() || request.auth == null;

      // Only authenticated users can create their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Only the owner can update or delete their profile
      allow update, delete: if isOwner(userId);
    }

    // Rules for the 'posts' collection
    match /posts/{postId} {
      // Allow read access to posts (more permissive for development)
      allow read: if isSignedIn() || request.auth == null;

      // Only authenticated users can create posts
      allow create: if isSignedIn();

      // Only the author can update or delete posts
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Rules for 'likes' subcollection
      match /likes/{userId} {
        allow read: if true; // Anyone can see who liked a post
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }

      // Rules for 'comments' subcollection
      match /comments/{commentId} {
        allow read: if true; // Anyone can read comments
        allow create, delete: if isSignedIn();
      }
    }

    // Rules for the 'stories' collection
    match /stories/{storyId} {
      allow read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for the 'reels' collection
    match /reels/{reelId} {
      allow read: if isSignedIn() || request.auth == null;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for the 'notifications' collection
    match /notifications/{notificationId} {
      allow read, create, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for conversations and messages
    match /conversations/{conversationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}