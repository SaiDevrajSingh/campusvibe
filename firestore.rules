rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Anyone can read a user's profile
      allow read: if true;

      // Only the authenticated user can create, update, or delete their own profile
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Rules for the 'posts' collection
    match /posts/{postId} {
      // Only authenticated users can read posts
      allow read: if isSignedIn();

      // Only authenticated users can create new posts
      allow create: if isSignedIn();

      // Only the author of a post can update or delete it
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Rules for 'likes' subcollection in a post
      match /likes/{userId} {
        // Anyone can read who liked a post
        allow read: if true;

        // Only authenticated users can like or unlike a post
        allow create, delete: if isSignedIn() && request.auth.uid == userId;
      }

      // Rules for 'comments' subcollection in a post
      match /comments/{commentId} {
        // Anyone can read comments
        allow read: if true;

        // Only authenticated users can add or delete comments
        allow create, delete: if isSignedIn();
      }
    }

    // Rules for the 'stories' collection
    match /stories/{storyId} {
      // Only authenticated users can read stories
      allow read: if isSignedIn();

      // Only authenticated users can create stories
      allow create: if isSignedIn();

      // Only the author of a story can delete it
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for the 'reels' collection
    match /reels/{reelId} {
      // Only authenticated users can read reels
      allow read: if isSignedIn();

      // Only authenticated users can create reels
      allow create: if isSignedIn();

      // Only the author of a reel can delete it
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for the 'notifications' collection
    match /notifications/{notificationId} {
      // Users can only read, create, or delete their own notifications
      allow read, create, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}